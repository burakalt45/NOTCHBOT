# ==========================================================
# GET USER STATUS
# ==========================================================

def get_user_presence(

    db: Session,

    user_id: int

):

    try:

        row = db.execute(

            text("""

            SELECT

                is_online,

                last_seen

            FROM user_presence

            WHERE

                user_id = :uid

            ORDER BY last_seen DESC

            LIMIT 1

            """),

            {

                "uid": user_id

            }

        ).fetchone()

        if row is None:

            return {

                "online": False,

                "last_seen": None

            }

        return {

            "online": row.is_online,

            "last_seen": row.last_seen

        }

    except Exception as e:

        logger.error(f"Presence Error: {e}")

        return {

            "online": False,

            "last_seen": None

        }


