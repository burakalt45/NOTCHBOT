    conversation_id: int

):

    try:

        db.execute(

            text("""

            INSERT INTO archived_conversations
            (

                user_id,

                conversation_id,

                archived_at

            )

            VALUES
            (

                :uid,

                :cid,

                NOW()

            )

            ON CONFLICT DO NOTHING

            """),

            {

                "uid": user_id,

                "cid": conversation_id

            }

        )

        db.commit()

        return True

    except Exception as e:

        logger.error(f"Archive Error: {e}")

