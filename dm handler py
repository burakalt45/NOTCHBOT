# BLOCK SYSTEM
# ==========================================================

def is_blocked(
    db: Session,
    user_a: int,
    user_b: int
) -> bool:

    try:

        row = db.execute(

            text("""

            SELECT 1

            FROM blocked_users

            WHERE

            (blocker_id=:a AND blocked_id=:b)

            OR

            (blocker_id=:b AND blocked_id=:a)

            LIMIT 1

            """),

            {

                "a": user_a,

                "b": user_b

            }

        ).fetchone()

        return row is not None

    except Exception:

        return False


