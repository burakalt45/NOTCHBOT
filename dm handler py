def get_messages_before(

    db: Session,

    conversation_id: int,

    before_message_id: int,

    limit: int = 30

):

    try:

        rows = db.execute(

            text("""

            SELECT *

            FROM direct_messages

            WHERE

                conversation_id = :cid

            AND

                id < :mid

            AND

                is_deleted = FALSE

            ORDER BY id DESC

            LIMIT :limit

            """),

            {

                "cid": conversation_id,

                "mid": before_message_id,

                "limit": limit

            }

        ).fetchall()

        return list(reversed(rows))

    except Exception as e:

        logger.error(f"Pagination Error: {e}")

        return []
