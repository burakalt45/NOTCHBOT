def search_messages(

    db: Session,

    conversation_id: int,

    keyword: str,

    limit: int = 50

):

    try:

        rows = db.execute(

            text("""

            SELECT

                uuid,

                sender_id,

                recipient_id,

                text,

                created_at

            FROM direct_messages

            WHERE

                conversation_id = :cid

            AND

                is_deleted = FALSE

            AND

                LOWER(text)

                LIKE LOWER(:search)

            ORDER BY created_at DESC

            LIMIT :limit

            """),

            {

                "cid": conversation_id,

                "search": f"%{keyword}%",

                "limit": limit

            }

        ).fetchall()

        return rows

    except Exception as e:

        logger.error(f"Search Error: {e}")

        sentry_sdk.capture_exception(e)

        return []


