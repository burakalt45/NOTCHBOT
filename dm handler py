def get_reactions(

    db: Session,

    message_uuid: str

):

    try:

        rows = db.execute(

            text("""

            SELECT

                emoji,

                COUNT(*) AS total

            FROM message_reactions

            WHERE

                message_uuid=:uuid

            GROUP BY emoji

            ORDER BY total DESC

            """),

            {

                "uuid": message_uuid

            }

        ).fetchall()

        return [

            {

                "emoji": r.emoji,

                "count": r.total

            }

            for r in rows

        ]

    except Exception as e:

        logger.error(f"Reaction List Error: {e}")

        return []
