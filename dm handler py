# ==========================================================
# SAVE MESSAGE
# ==========================================================

def save_dm(

    db: Session,

    sender_username: str,

    recipient_username: str,

    message: str,

    msg_type: str = "text",

    reply_to=None,

    attachment=None

):

    try:

        sender = user_by_username(db, sender_username)

        recipient = user_by_username(db, recipient_username)

        if sender is None or recipient is None:

            return False

        if msg_type not in MESSAGE_TYPES:

            return False

        if is_blocked(db, sender.id, recipient.id):

            return False

        conversation_id = get_or_create_conversation(

            db,

            sender.id,

            recipient.id

        )

        if conversation_id is None:

            return False

        message_uuid = generate_message_uuid()

        db.execute(

            text("""
                             INSERT INTO direct_messages
            (
                uuid,
                conversation_id,
                sender_id,
                recipient_id,
                text,
                msg_type,
                attachment,
                reply_to,
                status,
                is_read,
                is_deleted,
                edited,
                created_at,
                updated_at
            )

            VALUES
            (
                :uuid,
                :conversation_id,
                :sender,
                :recipient,
                :text,
                :msg_type,
                :attachment,
                :reply_to,
                'sent',
                FALSE,
                FALSE,
                FALSE,
                NOW(),
                NOW()
            )

            """),

            {

                "uuid": message_uuid,

                "conversation_id": conversation_id,

                "sender": sender.id,

                "recipient": recipient.id,

                "text": message[:MAX_MESSAGE_LENGTH],

                "msg_type": msg_type,

                "attachment": attachment,

                "reply_to": reply_to

            }

        )

        db.execute(

            text("""

            UPDATE conversations

            SET

                updated_at = NOW(),

                last_message = :msg

            WHERE id = :cid

            """),

            {

                "msg": message[:100],

                "cid": conversation_id

            }

        )

        db.commit()

        return True

    except Exception as e:

        logger.error(f"Save DM Error: {e}")

        sentry_sdk.capture_exception(e)

        db.rollback()

        return False


